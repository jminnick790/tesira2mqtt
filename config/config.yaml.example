tesira:
  host: "192.168.1.100"          # TODO: replace with Tesira IP
  port: 23
  username: "default"
  password: "default"
  reconnect_interval_s: 5
  subscription_min_rate_ms: 100

mqtt:
  host: "192.168.1.50"           # TODO: replace with Mosquitto IP
  port: 1883
  username: ""
  password: ""
  discovery_prefix: "homeassistant"
  device_name: "Biamp Tesira"
  device_id: "tesira_main"

# ── SOURCES ──────────────────────────────────────────────────────────────────
# Logical input names. Channel assignments live in routing blocks below.
# The same source can appear in multiple routing entries (feeds multiple zones).
#
# Channel convention: odd = Left, even = Right (e.g. ch 1=L, ch 2=R)
# This is consistent across all inputs and outputs in this design.
#
# Active router inputs:
#   Sonos Port  — ch 1 (L), 2 (R)
#   FPP         — ch 3 (L), 4 (R)
#   Dry Lines   — ch 15 (L), 16 (R)
#   Tone        — ch 31 (single channel, mono: true in routing entries)
#   White Noise — ch 32 (single channel, mono: true in routing entries)
#   (ch 5–14 reserved / unassigned in current design)
sources:
  - id: sonos_port
    name: "Sonos Port"
  - id: fpp
    name: "FPP"
  - id: dry_lines_in
    name: "Dry Lines"
  - id: tone
    name: "Tone"
  - id: noise
    name: "White Noise"

# ── ZONES ────────────────────────────────────────────────────────────────────
# Level instances: level_z1 – level_z10 (2-channel ganged blocks)
# level_channel: 0 = ganged control (moves both L and R together)
# mute_instance is not set — Level blocks expose mute on the same instance,
# so the bridge uses level_instance for both level and mute commands.
zones:
  - id: zone_01
    name: "Zone 01"              # TODO: rename (e.g. "Living Room")
    stereo: true
    # mono: true                 # Routes both L+R source channels to both outputs.
    #                            # Use for ambient spaces (porch, garage) where
    #                            # stereo imaging is not meaningful.
    level_instance: "level_z1"
    level_channel: 0
    min_db: -100.0
    max_db: 12.0

  - id: zone_02
    name: "Zone 02"
    stereo: true
    level_instance: "level_z2"
    level_channel: 0
    min_db: -100.0
    max_db: 12.0

  - id: zone_03
    name: "Zone 03"
    stereo: true
    level_instance: "level_z3"
    level_channel: 0
    min_db: -100.0
    max_db: 12.0

  - id: zone_04
    name: "Zone 04"
    stereo: true
    level_instance: "level_z4"
    level_channel: 0
    min_db: -100.0
    max_db: 12.0

  - id: zone_05
    name: "Zone 05"
    stereo: true
    level_instance: "level_z5"
    level_channel: 0
    min_db: -100.0
    max_db: 12.0

  - id: zone_06
    name: "Zone 06"
    stereo: true
    level_instance: "level_z6"
    level_channel: 0
    min_db: -100.0
    max_db: 12.0

  - id: zone_07
    name: "Zone 07"
    stereo: true
    level_instance: "level_z7"
    level_channel: 0
    min_db: -100.0
    max_db: 12.0

  - id: zone_08
    name: "Zone 08"
    stereo: true
    level_instance: "level_z8"
    level_channel: 0
    min_db: -100.0
    max_db: 12.0

  - id: zone_09
    name: "Zone 09"
    stereo: true
    level_instance: "level_z9"
    level_channel: 0
    min_db: -100.0
    max_db: 12.0

  - id: zone_10
    name: "Zone 10"
    stereo: true
    level_instance: "level_z10"
    level_channel: 0
    min_db: -100.0
    max_db: 12.0

# ── ROUTING ──────────────────────────────────────────────────────────────────
# Matrix instance: "matrix"
# Output channels: zone N = [2N-1, 2N]  (e.g. zone_01=[1,2], zone_02=[3,4])
# Input channels:  Sonos Port=[1,2]  FPP=[3,4]  Dry Lines=[15,16]
#                  Tone=[31]  White Noise=[32]  (single-channel — use mono: true)
#
# mono: true on a source entry fans a single input channel to all zone outputs.
# This is distinct from zone-level mono (which applies to all sources in the zone).
routing:
  - id: zone_01_source
    name: "Zone 01 Source"
    zone_id: zone_01
    matrix_instance: "matrix"
    output_channels: [1, 2]
    sources:
      - source_id: sonos_port
        input_channels: [1, 2]
      - source_id: fpp
        input_channels: [3, 4]
      - source_id: dry_lines_in
        input_channels: [15, 16]
      - source_id: tone
        input_channels: [31]
        mono: true             # single-channel — fans to both outputs
      - source_id: noise
        input_channels: [32]
        mono: true

  - id: zone_02_source
    name: "Zone 02 Source"
    zone_id: zone_02
    matrix_instance: "matrix"
    output_channels: [3, 4]
    sources:
      - source_id: sonos_port
        input_channels: [1, 2]
      - source_id: fpp
        input_channels: [3, 4]
      - source_id: dry_lines_in
        input_channels: [15, 16]

  - id: zone_03_source
    name: "Zone 03 Source"
    zone_id: zone_03
    matrix_instance: "matrix"
    output_channels: [5, 6]
    sources:
      - source_id: sonos_port
        input_channels: [1, 2]
      - source_id: fpp
        input_channels: [3, 4]
      - source_id: dry_lines_in
        input_channels: [15, 16]

  - id: zone_04_source
    name: "Zone 04 Source"
    zone_id: zone_04
    matrix_instance: "matrix"
    output_channels: [7, 8]
    sources:
      - source_id: sonos_port
        input_channels: [1, 2]
      - source_id: fpp
        input_channels: [3, 4]
      - source_id: dry_lines_in
        input_channels: [15, 16]

  - id: zone_05_source
    name: "Zone 05 Source"
    zone_id: zone_05
    matrix_instance: "matrix"
    output_channels: [9, 10]
    sources:
      - source_id: sonos_port
        input_channels: [1, 2]
      - source_id: fpp
        input_channels: [3, 4]
      - source_id: dry_lines_in
        input_channels: [15, 16]

  - id: zone_06_source
    name: "Zone 06 Source"
    zone_id: zone_06
    matrix_instance: "matrix"
    output_channels: [11, 12]
    sources:
      - source_id: sonos_port
        input_channels: [1, 2]
      - source_id: fpp
        input_channels: [3, 4]
      - source_id: dry_lines_in
        input_channels: [15, 16]

  - id: zone_07_source
    name: "Zone 07 Source"
    zone_id: zone_07
    matrix_instance: "matrix"
    output_channels: [13, 14]
    sources:
      - source_id: sonos_port
        input_channels: [1, 2]
      - source_id: fpp
        input_channels: [3, 4]
      - source_id: dry_lines_in
        input_channels: [15, 16]

  - id: zone_08_source
    name: "Zone 08 Source"
    zone_id: zone_08
    matrix_instance: "matrix"
    output_channels: [15, 16]
    sources:
      - source_id: sonos_port
        input_channels: [1, 2]
      - source_id: fpp
        input_channels: [3, 4]
      - source_id: dry_lines_in
        input_channels: [15, 16]

  - id: zone_09_source
    name: "Zone 09 Source"
    zone_id: zone_09
    matrix_instance: "matrix"
    output_channels: [17, 18]
    sources:
      - source_id: sonos_port
        input_channels: [1, 2]
      - source_id: fpp
        input_channels: [3, 4]
      - source_id: dry_lines_in
        input_channels: [15, 16]

  - id: zone_10_source
    name: "Zone 10 Source"
    zone_id: zone_10
    matrix_instance: "matrix"
    output_channels: [19, 20]
    sources:
      - source_id: sonos_port
        input_channels: [1, 2]
      - source_id: fpp
        input_channels: [3, 4]
      - source_id: dry_lines_in
        input_channels: [15, 16]
